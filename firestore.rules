rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Only allow updating totalPoints and streakCount (not email, username, etc.)
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPoints', 'streakCount']);      
    }

    // Usernames lookup Collection
    // - Any authenticated user can read (required for real-time availability check)
    // - Write is only allowed via server-side transaction from the owner's UID
    match /usernames/{username} {
      allow get: if true;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    
    // Tasks Collection
    match /tasks/{taskId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) 
        && request.resource.data.points > 0 
        && request.resource.data.points <= 1000;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Logs Collection
    match /logs/{logId} {
      allow read: if resource == null || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // Rewards Collection
    match /rewards/{rewardId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && request.resource.data.cost > 0;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Redemptions Collection
    match /redemptions/{redemptionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId);
    }
  }
}
